// ── MONTHLY STOCK CALCULATOR ──
// Returns closing stock for every day of a month for a specific item
function getMonthlyStock(b) {
  const month    = b.month;    // format: 'YYYY-MM'
  const itemName = b.itemName;
  if (!month || !itemName) throw new Error('month and itemName required');

  const items   = getItems();
  const item    = items.find(i => i.name.toLowerCase() === itemName.toLowerCase());
  if (!item) throw new Error('Item not found: ' + itemName);

  const inRows  = getRows(SH.INWARD);
  const outRows = getRows(SH.OUTWARD);
  const openMap = getOpeningMap();

  // Get last day of month
  const [yr, mo] = month.split('-').map(Number);
  const lastDay = new Date(yr, mo, 0).getDate();

  const result = [];

  for (let d = 1; d <= lastDay; d++) {
    const date = month + '-' + String(d).padStart(2, '0');

    const prevIn  = inRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) < date)
                          .reduce((s,r) => s + (Number(r[3])||0), 0);
    const prevOut = outRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) < date)
                           .reduce((s,r) => s + (Number(r[3])||0), 0);
    const opening = (openMap[item.name] || 0) + prevIn - prevOut;

    const tIn  = inRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) === date)
                       .reduce((s,r) => s + (Number(r[3])||0), 0);
    const tOut = outRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) === date)
                        .reduce((s,r) => s + (Number(r[3])||0), 0);
    const closing = opening + tIn - tOut;

    result.push({
      date,
      opening,
      inward:  tIn,
      outward: tOut,
      closing,
    });
  }

  return {
    itemName: item.name,
    unit:     item.unit,
    maxL:     item.maxL || 0,
    minL:     item.minL || 0,
    month,
    days: result,
  };
}

// ── MONTHLY STOCK ALL ITEMS ──
function getMonthlyStockAll(b) {
  const month = b.month;
  if (!month) throw new Error('month required');

  const [yr, mo] = month.split('-').map(Number);
  const lastDay  = new Date(yr, mo, 0).getDate();

  // Cap to today — future dates nahi dikhne chahiye
  const todayStr = today();
  const todayMonth = todayStr.slice(0, 7);
  const effectiveLastDay = (month === todayMonth)
    ? Math.min(lastDay, parseInt(todayStr.slice(8, 10)))
    : lastDay;

  const dates = [];
  for (let d = 1; d <= effectiveLastDay; d++) {
    dates.push(month + '-' + String(d).padStart(2, '0'));
  }

  const items   = getItems();
  const inRows  = getRows(SH.INWARD);
  const outRows = getRows(SH.OUTWARD);
  const openMap = getOpeningMap();

  const result = items.map(item => {
    // Find first date this item has any data
    const hasOpening = (openMap[item.name] || 0) > 0;

    // First inward date for this item
    const itemInDates  = inRows.filter(r => String(r[2]||'') === item.name).map(r => fmtDate(r[1])).filter(Boolean);
    const itemOutDates = outRows.filter(r => String(r[2]||'') === item.name).map(r => fmtDate(r[1])).filter(Boolean);
    const allDates     = [...itemInDates, ...itemOutDates].sort();
    const firstTxnDate = allDates.length ? allDates[0] : null;

    // Opening stock set date
    const openingRows = SpreadsheetApp.openById(SHEET_ID).getSheetByName(SH.OPENING)
                          .getDataRange().getValues().slice(1)
                          .filter(r => String(r[0]||'').toLowerCase() === item.name.toLowerCase());
    const openingSetDate = openingRows.length ? fmtDate(openingRows[0][4]) : null;

    // First date from which we have data
    const candidates = [firstTxnDate, openingSetDate].filter(Boolean).sort();
    const firstDataDate = candidates.length ? candidates[0] : null;

    const closings = dates.map(date => {
      // Before first data date — show null
      if (firstDataDate && date < firstDataDate) return null;

      const prevIn  = inRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) < date)
                            .reduce((s,r) => s + (Number(r[3])||0), 0);
      const prevOut = outRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) < date)
                             .reduce((s,r) => s + (Number(r[3])||0), 0);
      const opening = (openMap[item.name] || 0) + prevIn - prevOut;
      const tIn  = inRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) === date)
                         .reduce((s,r) => s + (Number(r[3])||0), 0);
      const tOut = outRows.filter(r => String(r[2]||'') === item.name && fmtDate(r[1]) === date)
                          .reduce((s,r) => s + (Number(r[3])||0), 0);
      return opening + tIn - tOut;
    });

    return { name: item.name, unit: item.unit, maxL: item.maxL || 0, closings };
  });

  return { month, days: dates, items: result };
}


