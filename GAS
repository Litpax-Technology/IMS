// ── ITEMS ──
function getItems() {
  return getRows(SH.ITEMS).map(r => ({
    name: String(r[0]||''), cat: String(r[1]||''), unit: String(r[2]||''),
    adc: Number(r[3])||0, lt: Number(r[4])||0, sf: Number(r[5])||1.2,
    moq: Number(r[6])||0, maxL: Number(r[7])||0, minL: Number(r[8])||0,
    mit: Number(r[9])||0, remarks: String(r[10]||''),
  })).filter(i => i.name);
}
function addItem(b) {
  const items = getItems();
  if (items.find(i => i.name.toLowerCase() === (b.name||'').toLowerCase()))
    throw new Error('Item already exists: ' + b.name);
  const maxL = Number(b.maxL) || Math.ceil((Number(b.adc)||0)*(Number(b.lt)||0)*(Number(b.sf)||1.2));
  const rp   = Math.ceil(maxL / 2);
  getSheet(SH.ITEMS).appendRow([b.name, b.cat||'Raw Material', b.unit||'',
    Number(b.adc)||0, Number(b.lt)||0, Number(b.sf)||1.2,
    Number(b.moq)||rp, maxL, rp,
    Number(b.mit)||0, b.remarks||'', nowISO()]);
  return { success: true };
}
function updateItem(b) {
  const sh = getSheet(SH.ITEMS);
  const rows = sh.getDataRange().getValues();
  const search = (b.originalName||b.name).toLowerCase();
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0].toString().toLowerCase() === search) {
      const maxL2 = Number(b.maxL) || Math.ceil((Number(b.adc)||0)*(Number(b.lt)||0)*(Number(b.sf)||1.2));
      const rp   = Math.ceil(maxL2 / 2);
      sh.getRange(i+1,1,1,12).setValues([[b.name,b.cat,b.unit||'',
        Number(b.adc)||0,Number(b.lt)||0,Number(b.sf)||1.2,
        Number(b.moq)||rp, maxL2, rp,
        Number(b.mit)||0,b.remarks||'',rows[i][11]]]);
      return { success: true };
    }
  }
  throw new Error('Item not found: '+b.name);
}
function deleteItem(b) {
  const sh = getSheet(SH.ITEMS);
  const rows = sh.getDataRange().getValues();
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0].toString().toLowerCase() === (b.name||'').toLowerCase()) {
      sh.deleteRow(i+1); return { success: true };
    }
  }
  throw new Error('Item not found');
}
function updateMIT(itemName, delta) {
  const sh = getSheet(SH.ITEMS);
  const rows = sh.getDataRange().getValues();
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0].toString().toLowerCase() === itemName.toLowerCase()) {
      sh.getRange(i+1,10).setValue(Math.max(0,(Number(rows[i][9])||0)+delta));
      return;
    }
  }
}

// ── OPENING STOCK ──
function getOpeningStock() {
  return getRows(SH.OPENING).map(r => ({
    name:    String(r[0]||''),
    sku:     String(r[1]||''),
    qty:     Number(r[2])||0,
    unit:    String(r[3]||''),
