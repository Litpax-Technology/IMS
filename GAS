// ── DAILY CLOSING ──
function getClosing(b) {
  const date = (b&&b.date) ? b.date : today();
  const items = getItems();
  const inRows  = getRows(SH.INWARD);
  const outRows = getRows(SH.OUTWARD);
  const openMap = getOpeningMap();
  return items.map(item => {
    const prevIn  = inRows.filter(r => String(r[2]||'')===item.name && fmtDate(r[1])<date).reduce((s,r)=>s+(Number(r[3])||0),0);
    const prevOut = outRows.filter(r => String(r[2]||'')===item.name && fmtDate(r[1])<date).reduce((s,r)=>s+(Number(r[3])||0),0);
    const opening = (openMap[item.name]||0) + prevIn - prevOut;
    const tIn  = inRows.filter(r => String(r[2]||'')===item.name && fmtDate(r[1])===date).reduce((s,r)=>s+(Number(r[3])||0),0);
    const tOut = outRows.filter(r => String(r[2]||'')===item.name && fmtDate(r[1])===date).reduce((s,r)=>s+(Number(r[3])||0),0);
    const closing = opening + tIn - tOut;
    const rp = Math.ceil((item.adc||0)*(item.lt||0)*(item.sf||1));
    return { name:item.name, cat:item.cat, unit:item.unit, opening, todayIn:tIn, todayOut:tOut, closing, mit:item.mit||0, reorderPoint:rp, status: closing<=0?'Critical':closing<=rp?'Reorder':'OK' };
  });
}

// ── SNAPSHOT ──
function saveSnapshot(b) {
  const date = (b&&b.date) ? b.date : today();
  const rows = getClosing({ date });
  const sh = getSheet(SH.SNAPSHOT);
  rows.forEach(r => sh.appendRow([date,r.name,r.cat,r.unit,r.opening,r.todayIn,r.todayOut,r.closing,r.mit,r.reorderPoint,r.status]));
  return { success: true, rows: rows.length };
}

// ── CLOSING HISTORY ──
function getClosingHistory(b) {
  const from = b&&b.from ? b.from : today();
  const to   = b&&b.to   ? b.to   : today();
  const rows = getRows(SH.SNAPSHOT);
  const filtered = rows.filter(r => { const d=fmtDate(r[0]); return d>=from && d<=to; });
  if (!filtered.length) return [];
  const byDate = {};
  filtered.forEach(r => {
    const d = fmtDate(r[0]);
    if (!byDate[d]) byDate[d] = [];
    byDate[d].push({ date:d, name:String(r[1]||''), cat:String(r[2]||''), unit:String(r[3]||''), opening:Number(r[4])||0, todayIn:Number(r[5])||0, todayOut:Number(r[6])||0, closing:Number(r[7])||0, mit:Number(r[8])||0, reorderPoint:Number(r[9])||0, status:String(r[10]||'') });
  });
  return Object.keys(byDate).sort().map(date => ({
    date, rows: byDate[date],
    totalIn: byDate[date].reduce((s,r)=>s+r.todayIn,0),
    totalOut: byDate[date].reduce((s,r)=>s+r.todayOut,0),
    alerts: byDate[date].filter(r=>r.status!=='OK').length,
  }));
}

