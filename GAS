function setOpeningStock(b) {
  const sh = getSheet(SH.OPENING);
  const rows = sh.getDataRange().getValues();
  const existing = {};
  for (let i = 1; i < rows.length; i++) {
    existing[String(rows[i][0]||'').toLowerCase()] = i + 1;
  }
  const date = today();
  (b.items||[]).forEach(item => {
    const key = item.name.toLowerCase();
    if (existing[key]) {
      sh.getRange(existing[key],1,1,6).setValues([[item.name, item.sku||'', Number(item.qty)||0, item.unit||'', date, item.remarks||'']]);
    } else {
      sh.appendRow([item.name, item.sku||'', Number(item.qty)||0, item.unit||'', date, item.remarks||'']);
    }
    updateSKU(item.name, item.sku||'');
  });
  return { success: true };
}
function updateSKU(itemName, sku) {}
function getOpeningMap() {
  const map = {};
  getOpeningStock().forEach(r => { map[r.name] = r.qty; });
  return map;
}

// ── STOCKS CALCULATOR ──
function calcStocks() {
  const items    = getItems();
  const inRows   = getRows(SH.INWARD);
  const outRows  = getRows(SH.OUTWARD);
  const disRows  = getRows(SH.DISPATCH);
  const openMap  = getOpeningMap();

  const storeMap = {};
  items.forEach(i => { storeMap[i.name] = openMap[i.name] || 0; });
  inRows.forEach(r => {
    const name = String(r[2]||'');
    if (storeMap[name] !== undefined) storeMap[name] += Number(r[3])||0;
  });
  outRows.forEach(r => {
    const name = String(r[2]||'');
    const remarks = String(r[8]||'');
    // Purani dispatch entries ignore karo (nayi entries Outward mein nahi aayengi)
    if (remarks.startsWith('Dispatch:') || remarks.startsWith('Direct Dispatch:')) return;
    if (storeMap[name] !== undefined) storeMap[name] -= Number(r[3])||0;
  });


  // WIP = Total Outward (Production only) - From Production returns - Dispatch Used
  const manualOut = {};
  items.forEach(i => { manualOut[i.name] = 0; });
  outRows.forEach(r => {
    const name = String(r[2]||''), qty = Number(r[3])||0;
    const remarks = String(r[8]||'');
    const purpose = String(r[10]||'Production');
    // Purani dispatch entries ignore karo
    if (remarks.startsWith('Dispatch:') || remarks.startsWith('Direct Dispatch:')) return;
    // Sirf Production purpose wale WIP mein count honge
    if (purpose !== 'Production') return;
    if (manualOut[name] !== undefined) manualOut[name] += qty;
  });
  // From Production returns - WIP se minus karo
  inRows.forEach(r => {
    const name = String(r[2]||'');
    const purpose = String(r[10]||'Raw Material');
    const qty = Number(r[3])||0;
    if (purpose === 'From Production' && manualOut[name] !== undefined) {
      manualOut[name] = Math.max(0, manualOut[name] - qty);
    }
  });

  // Dispatch sheet se consumed components calculate karo via BOM
  const dispUsed = {};
  items.forEach(i => { dispUsed[i.name] = 0; });
  disRows.forEach(r => {
    const bomName  = String(r[2]||'');
    const dispQty  = Number(r[3])||0;
    const verified = String(r[7]||'');
    if (!bomName || !dispQty) return;

    if (verified === 'Direct') {
      // Direct Dispatch — item name directly in dispUsed
      if (dispUsed[bomName] !== undefined) dispUsed[bomName] += dispQty;
    } else {
      // BOM-based dispatch — calculate component consumption
      try {
        const bomItems = getBomItems({ bomName: bomName });
        bomItems.forEach(bi => {
          const comp = bi.component;
          if (dispUsed[comp] !== undefined) dispUsed[comp] += bi.qty * dispQty;
        });
      } catch(e) {}
    }
  });

  const wipMap = {};
  items.forEach(i => { wipMap[i.name] = Math.max(0,(manualOut[i.name]||0)-(dispUsed[i.name]||0)); });

  return items.map(item => {
    const cs  = storeMap[item.name] || 0;
    const wip = wipMap[item.name]   || 0;
    const op  = openMap[item.name]  || 0;
    const rp  = item.minL || Math.ceil(((item.adc||0)*(item.lt||0)*(item.sf||1)) / 2);
    const sto = Math.max(0,(item.maxL||0)-cs-(item.mit||0));
    const status = cs <= 0 ? 'Critical' : cs <= rp ? 'Reorder' : 'OK';
    return { ...item, currentStock: cs, wip, openingStock: op, reorderPoint: rp, stockToOrder: sto, status, totalOut: manualOut[item.name]||0, dispUsed: dispUsed[item.name]||0 };
  });
}

function getFGSummary() {
  const disRows = getRows(SH.DISPATCH);
  const fgMap = {};
  disRows.forEach(r => {
    const model = String(r[2]||''), qty = Number(r[3])||0, date = fmtDate(r[1]);
    if (!fgMap[model]) fgMap[model] = { model, totalProduced: 0, lastDate: '' };
    fgMap[model].totalProduced += qty;
    if (date > fgMap[model].lastDate) fgMap[model].lastDate = date;
  });
  return Object.values(fgMap);
}

// ── BOM MODELS ──
function getBomModels() {
  return getRows(SH.BOM_MODELS).map(r => ({
    bomName: String(r[0]||''), alias: String(r[1]||''),
    produces: String(r[2]||''), unit: String(r[3]||'Pcs'),
    active: String(r[4]||'YES'), remarks: String(r[5]||''),
  })).filter(r => r.bomName);
}
function addBomModel(b) {
  const models = getBomModels();
  if (models.find(m => m.bomName.toLowerCase() === (b.bomName||'').toLowerCase()))
    throw new Error('BOM already exists: '+b.bomName);
  getSheet(SH.BOM_MODELS).appendRow([b.bomName,b.alias||'',b.produces||b.bomName,'Pcs','YES',b.remarks||'']);
  return { success: true };
}
function deleteBomModel(b) {
  const sh = getSheet(SH.BOM_MODELS);
  const rows = sh.getDataRange().getValues();
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0].toString().toLowerCase() === (b.bomName||'').toLowerCase()) {
      sh.deleteRow(i+1); deleteBomItemsFor(b.bomName); return { success: true };
    }
  }
  throw new Error('BOM not found');
}
function getBomItems(b) {
  const rows = getRows(SH.BOM_ITEMS);
  const all = rows.map(r => ({ bomName: String(r[0]||''), component: String(r[1]||''), qty: Number(r[2])||0, unit: String(r[3]||'') })).filter(r => r.bomName);
  if (b && b.bomName) return all.filter(r => r.bomName.toLowerCase() === b.bomName.toLowerCase());
  return all;
}
function saveBomItems(b) {
  deleteBomItemsFor(b.bomName);
  const sh = getSheet(SH.BOM_ITEMS);
  (b.items||[]).forEach(item => sh.appendRow([b.bomName, item.component, Number(item.qty)||0, item.unit||'Pcs']));
  return { success: true };
}
function deleteBomItemsFor(bomName) {
  const sh = getSheet(SH.BOM_ITEMS);
  const rows = sh.getDataRange().getValues();
  for (let i = rows.length-1; i >= 1; i--) {
    if (rows[i][0].toString().toLowerCase() === bomName.toLowerCase()) sh.deleteRow(i+1);
  }
}

// ── INWARD ──
function getInward(b) {
  let rows = getRows(SH.INWARD).map(r => ({
    id: String(r[0]||''), date: fmtDate(r[1]), itemName: String(r[2]||''),
    qty: Number(r[3])||0, unit: String(r[4]||''), supplier: String(r[5]||''),
    invoice: String(r[6]||''), by: String(r[7]||''), remarks: String(r[8]||''), ts: String(r[9]||''),
    purpose: String(r[10]||'Raw Material'),
  })).filter(r => r.itemName);
  if (b && b.date) rows = rows.filter(r => r.date === b.date);
  if (b && b.itemName) rows = rows.filter(r => r.itemName === b.itemName);
  return rows.reverse();
}
function addInward(b) {
  const items = getItems();
  const item = items.find(i => i.name.toLowerCase() === (b.itemName||'').toLowerCase());
  if (!item) throw new Error('Item not found: '+b.itemName);
  const id = uid('IN');
  getSheet(SH.INWARD).appendRow([id, b.date||today(), item.name, Number(b.qty)||0, item.unit, b.supplier||'', b.invoice||'', b.by||'Store', b.remarks||'', nowISO(), b.purpose||'Raw Material']);
  if (b.indentId) receiveIndent({ id: b.indentId, itemName: item.name, qty: Number(b.qty)||0, date: b.date||today(), invoice: b.invoice||'' });
  return { success: true, id };
}

// ── OUTWARD ──
function getOutward(b) {
  let rows = getRows(SH.OUTWARD).map(r => ({
    id: String(r[0]||''), date: fmtDate(r[1]), itemName: String(r[2]||''),
    qty: Number(r[3])||0, unit: String(r[4]||''), department: String(r[5]||''),
    issuedTo: String(r[6]||''), by: String(r[7]||''), remarks: String(r[8]||''), ts: String(r[9]||''),
    purpose: String(r[10]||'Production'),
  })).filter(r => r.itemName);
  if (b && b.date) rows = rows.filter(r => r.date === b.date);
  if (b && b.department) rows = rows.filter(r => r.department === b.department);
  return rows.reverse();
}
function addOutward(b) {
  const stocks = calcStocks();
  const stock = stocks.find(s => s.name.toLowerCase() === (b.itemName||'').toLowerCase());
  if (!stock) throw new Error('Item not found: '+b.itemName);
  if (Number(b.qty) > stock.currentStock)
    throw new Error('Insufficient stock. Available: '+stock.currentStock+' '+stock.unit);
  const id = uid('OUT');
  getSheet(SH.OUTWARD).appendRow([id, b.date||today(), stock.name, Number(b.qty)||0, stock.unit, b.department||'', b.issuedTo||'', b.by||'Store', b.remarks||'', nowISO(), b.purpose||'Production']);
  return { success: true, id };
}

// ── DISPATCH ──
function getDispatch(b) {
  let rows = getRows(SH.DISPATCH).map(r => ({
    id: String(r[0]||''), date: fmtDate(r[1]), bomModel: String(r[2]||''),
    qtyProduced: Number(r[3])||0, dispatchTo: String(r[4]||''),
    orderRef: String(r[5]||''), by: String(r[6]||''), bomVerified: String(r[7]||''),
    remarks: String(r[8]||''), ts: String(r[9]||''),
  })).filter(r => r.bomModel);
  if (b && b.date) rows = rows.filter(r => r.date === b.date);
  return rows.reverse();
}
function addDispatch(b) {
  const bomItems = getBomItems({ bomName: b.bomModel });
  if (!bomItems.length) throw new Error('BOM items not found for: '+b.bomModel);
  const qty = Number(b.qtyProduced)||1;
  const stocks = calcStocks();
  const shortages = [];
  bomItems.forEach(bi => {
    const needed = bi.qty * qty;
    const s = stocks.find(x => x.name.toLowerCase() === bi.component.toLowerCase());
    if (!s) {
      shortages.push(bi.component + ': not in Items');
    } else {
      // Store stock + WIP dono milake check — production mein jo hai woh bhi count karo
      const available = s.currentStock + (s.wip || 0);
      if (available < needed) {
        shortages.push(bi.component + ': chahiye ' + needed + ' ' + s.unit + ', available ' + available + ' (store: ' + s.currentStock + ' + production: ' + (s.wip||0) + ')');
      }
    }
  });
  if (shortages.length) throw new Error('Stock shortage:\n'+shortages.join('\n'));
  const date = b.date||today();
  const dispId = uid('DIS');
  getSheet(SH.DISPATCH).appendRow([dispId, date, b.bomModel, qty, b.dispatchTo||'', b.orderRef||'', b.by||'Production', 'YES', b.remarks||'', nowISO()]);
  return { success: true, id: dispId, componentsConsumed: bomItems.length };
}

function updateDispatch(b) {
  const sh   = getSheet(SH.DISPATCH);
  const rows = sh.getDataRange().getValues();
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0] === b.id) {
      sh.getRange(i+1, 2).setValue(b.date     || rows[i][1]);
      sh.getRange(i+1, 4).setValue(Number(b.qtyProduced) || rows[i][3]);
      sh.getRange(i+1, 5).setValue(b.dispatchTo !== undefined ? b.dispatchTo : rows[i][4]);
      sh.getRange(i+1, 6).setValue(b.orderRef  !== undefined ? b.orderRef   : rows[i][5]);
      sh.getRange(i+1, 9).setValue(b.remarks   !== undefined ? b.remarks    : rows[i][8]);
      return { success: true };
    }
  }
  throw new Error('Dispatch not found');
}

function deleteDispatch(b) {
  const sh   = getSheet(SH.DISPATCH);
  const rows = sh.getDataRange().getValues();
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0] === b.id) {
      sh.deleteRow(i + 1);
      return { success: true };
    }
  }
  throw new Error('Dispatch not found');
}


function addDirectDispatch(b) {
  const itemName = b.itemName;
  const qty      = Number(b.qty) || 0;
  if (!itemName) throw new Error('Item name required');
  if (qty <= 0)  throw new Error('Qty must be greater than 0');

  // Check WIP for this item
  const stocks = calcStocks();
  const stock  = stocks.find(s => s.name.toLowerCase() === itemName.toLowerCase());
  if (!stock) throw new Error('Item not found: ' + itemName);

  const wip = stock.wip || 0;
  if (wip <= 0) throw new Error(itemName + ' WIP mein nahi hai — pehle store se outward karo');
  if (qty > wip) throw new Error('Insufficient WIP. Available: ' + wip + ' ' + stock.unit + ', Requested: ' + qty);

  const date = b.date || today();

  // Add dispatch entry only
  const dispId = uid('DIS');
  getSheet(SH.DISPATCH).appendRow([
    dispId, date, stock.name, qty,
    b.dispatchTo || '', b.orderRef || '',
    b.by || 'Sandeep', 'Direct',
    (b.invoiceNo ? 'INV: ' + b.invoiceNo + ' | ' : '') + (b.remarks || ''),
    nowISO()
  ]);

  return { success: true, id: dispId, itemName: stock.name, qty, wip, remaining: wip - qty };
}


