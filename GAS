// ── ROUTING ──
function doGet(e) {
  const action = e && e.parameter ? e.parameter.action : null;
  return respond(action ? handleAction(action, e.parameter) : { status: 'Litpax IMS v3 OK' });
}
function doPost(e) {
  let body = {};
  try { body = JSON.parse(e.postData.contents); } catch(err) {}
  return respond(handleAction(body.action, body));
}
function respond(data) {
  return ContentService.createTextOutput(JSON.stringify(data)).setMimeType(ContentService.MimeType.JSON);
}
function handleAction(action, body) {
  try {
    switch(action) {
      case 'getItems':          return getItems();
      case 'getConfig':         return getConfig();
      case 'setupConfig':       return setupConfig();
      case 'addItem':           return addItem(body);
      case 'updateItem':        return updateItem(body);
      case 'deleteItem':        return deleteItem(body);
      case 'getBomModels':      return getBomModels();
      case 'addBomModel':       return addBomModel(body);
      case 'getBomItems':       return getBomItems(body);
      case 'saveBomItems':      return saveBomItems(body);
      case 'deleteBomModel':    return deleteBomModel(body);
      case 'getInward':         return getInward(body);
      case 'addInward':         return addInward(body);
      case 'getOutward':        return getOutward(body);
      case 'addOutward':        return addOutward(body);
      case 'getDispatch':       return getDispatch(body);
      case 'addDispatch':        return addDispatch(body);
      case 'addDirectDispatch':  return addDirectDispatch(body);
      case 'updateDispatch':     return updateDispatch(body);
      case 'deleteDispatch':     return deleteDispatch(body);
      case 'getDashboard':      return getDashboard();
      case 'getStockSummary':   return getStockSummary();
      case 'getClosing':        return getClosing(body);
      case 'saveSnapshot':      return saveSnapshot(body);
      case 'getClosingHistory': return getClosingHistory(body);
      case 'getMonthlyStock':    return getMonthlyStock(body);
      case 'getMonthlyStockAll': return getMonthlyStockAll(body);
      case 'getOpeningStock':   return getOpeningStock();
      case 'setOpeningStock':   return setOpeningStock(body);
      case 'getIndents':        return getIndents(body);
      case 'addIndent':         return addIndent(body);
      case 'receiveIndent':     return receiveIndent(body);
      case 'cancelIndent':      return cancelIndent(body);
      case 'migrateCategories':  return migrateCategories();
      case 'getRequests':       return getRequests(body);
      case 'addRequest':        return addRequest(body);
      case 'addRequestBulk':    return addRequestBulk(body);
      case 'closeRequest':      return closeRequest(body);
      case 'cancelRequest':     return cancelRequest(body);
      default: return { error: 'Unknown action: ' + action };
    }
  } catch(e) { return { error: e.message }; }
}

// ── SHEET HELPERS ──
function getSheet(name) {
  const ss = SpreadsheetApp.openById(SHEET_ID);
  let sh = ss.getSheetByName(name);
  if (!sh) sh = createNewSheet(ss, name);
  return sh;
}
function createNewSheet(ss, name) {
  const sh = ss.insertSheet(name);
  const hStyle = (s, n) => s.getRange(1,1,1,n).setBackground('#162444').setFontColor('#fff').setFontWeight('bold');
  if (name === SH.OPENING) {
    sh.appendRow(['Item Name','SKU Code','Opening Qty','Unit','Set Date','Remarks']);
    hStyle(sh, 6);
  }
  if (name === SH.REQUESTS) {
    sh.appendRow(['Req ID','Date','Time','Item Name','Qty Requested','Unit','Department','Requested By','Remarks','Status','Closed By','Closed At']);
    hStyle(sh, 12);
  }
  if (name === SH.INDENT) {
    sh.appendRow(['Indent ID','Date','Item Name','SKU','Qty','Unit','Supplier','Expected Date','Status','Invoice No','Received Qty','Received Date','Remarks','Created At']);
    hStyle(sh, 14);
  }
  return sh;
}
function getRows(name) {
  const sh = getSheet(name);
  const data = sh.getDataRange().getValues();
  if (data.length <= 1) return [];
  return data.slice(1);
}
function today() { return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd'); }
function fmtDate(val) {
  if (!val) return '';
  if (val instanceof Date) return Utilities.formatDate(val, Session.getScriptTimeZone(), 'yyyy-MM-dd');
  return String(val).slice(0, 10);
}
function nowISO() { return new Date().toISOString(); }
function uid(prefix) { return prefix + Date.now().toString(36).toUpperCase(); }

// ── CONFIG ──
// Config sheet structure:
// Row 1: Headers — Type | Key | Values (comma separated) | Remarks
// Types: category, unit, department, role
function getConfig() {
  const sh = getSheet(SH.CONFIG);
  const rows = sh.getDataRange().getValues().slice(1);
  
  const categories = [];
  const brands = {};
  const units = [];
  const departments = [];
  const catUnits = {};
  const catOrder = [];
  const noBrandCats = [];

  rows.forEach(r => {
    const type   = String(r[0]||'').trim();
    const key    = String(r[1]||'').trim();
    const values = String(r[2]||'').split(',').map(v => v.trim()).filter(Boolean);
    const extra  = String(r[3]||'').trim();

    if (type === 'category') {
      categories.push(key);
      catOrder.push(key);
      brands[key] = values.length ? values : ['Other'];
      catUnits[key] = extra || 'Pcs';
      if (String(r[4]||'').trim() === 'no-brand') noBrandCats.push(key);
    }
    if (type === 'unit') units.push(key);
    if (type === 'department') departments.push(key);
  });

  const roles = {};
  rows.forEach(r => {
    const type = String(r[0]||'').trim();
    const key  = String(r[1]||'').trim();
    const val  = String(r[2]||'').trim();
    if (type === 'role' && key) roles[key] = val;
  });

  return { categories, brands, units, departments, catUnits, catOrder, noBrandCats, roles };
}

